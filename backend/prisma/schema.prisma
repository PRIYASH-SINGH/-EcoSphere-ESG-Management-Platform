datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ==========================================
// 1. CORE & IDENTITY MODULES
// ==========================================

model Organization {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                String   @db.VarChar(255)
  taxIdentifier       String?  @map("tax_identifier") @db.VarChar(100)
  industrySector      String?  @map("industry_sector") @db.VarChar(100)
  headquartersCountry String?  @map("headquarters_country") @db.VarChar(100)
  
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  createdBy           String?  @map("created_by") @db.Uuid
  updatedBy           String?  @map("updated_by") @db.Uuid
  isDeleted           Boolean  @default(false) @map("is_deleted")
  deletedAt           DateTime? @map("deleted_at") @db.Timestamptz

  // Audit Relations
  createdByUser       User?    @relation("OrgCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict, onUpdate: Restrict)
  updatedByUser       User?    @relation("OrgUpdatedBy", fields: [updatedBy], references: [id], onDelete: Restrict, onUpdate: Restrict)

  // Reverse Relations
  users               User[]   @relation("OrgUsers")
  roles               Role[]
  permissions         Permission[]
  locations           Location[]
  departments         Department[]
  carbonEmissions     CarbonEmission[]
  energyConsumptions  EnergyConsumption[]
  waterConsumptions   WaterConsumption[]
  wasteManagements    WasteManagement[]
  renewableEnergies   RenewableEnergy[]
  environmentalGoals  EnvironmentalGoal[]
  csrActivities       CsrActivity[]
  volunteerPrograms   VolunteerProgram[]
  trainingRecords     TrainingRecord[]
  healthSafetyMetrics HealthSafetyMetric[]
  diversityMetrics    DiversityMetric[]
  audits              Audit[]
  complianceIssues    ComplianceIssue[]
  policies            Policy[]
  riskRegisters       RiskRegister[]
  boardMembers        BoardMember[]
  incidents           Incident[]
  challenges          Challenge[]
  rewards             Reward[]
  badges              Badge[]
  leaderboards        Leaderboard[]
  reportTemplates     ReportTemplate[]
  generatedReports    GeneratedReport[]
  kpiMetrics          KpiMetric[]
  settings            Setting[]

  @@map("organizations")
}

model User {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  email          String   @db.VarChar(255)
  passwordHash   String   @map("password_hash") @db.VarChar(255)
  firstName      String?  @map("first_name") @db.VarChar(100)
  lastName       String?  @map("last_name") @db.VarChar(100)
  isActive       Boolean  @default(true) @map("is_active")
  mfaEnabled     Boolean  @default(false) @map("mfa_enabled")
  mfaSecret      String?  @map("mfa_secret") @db.VarChar(100)
  
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  createdBy      String?  @map("created_by") @db.Uuid
  updatedBy      String?  @map("updated_by") @db.Uuid
  isDeleted      Boolean  @default(false) @map("is_deleted")
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz

  // Core Relations
  organization   Organization @relation("OrgUsers", fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  
  // Audit Relations (Self & Target Models)
  createdByUser  User?    @relation("UserCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict, onUpdate: Restrict)
  updatedByUser  User?    @relation("UserUpdatedBy", fields: [updatedBy], references: [id], onDelete: Restrict, onUpdate: Restrict)

  usersCreated   User[]   @relation("UserCreatedBy")
  usersUpdated   User[]   @relation("UserUpdatedBy")
  orgsCreated    Organization[] @relation("OrgCreatedBy")
  orgsUpdated    Organization[] @relation("OrgUpdatedBy")

  rolesCreated   Role[]   @relation("RoleCreatedBy")
  rolesUpdated   Role[]   @relation("RoleUpdatedBy")
  userRoles      UserRole[]
  userRolesCreated UserRole[] @relation("UserRoleCreatedBy")
  userRolesUpdated UserRole[] @relation("UserRoleUpdatedBy")

  permissionsCreated Permission[] @relation("PermissionCreatedBy")
  permissionsUpdated Permission[] @relation("PermissionUpdatedBy")
  rolePermissionsCreated RolePermission[] @relation("RolePermCreatedBy")
  rolePermissionsUpdated RolePermission[] @relation("RolePermUpdatedBy")

  locationsCreated Location[] @relation("LocCreatedBy")
  locationsUpdated Location[] @relation("LocUpdatedBy")

  departmentsCreated Department[] @relation("DeptCreatedBy")
  departmentsUpdated Department[] @relation("DeptUpdatedBy")

  teamsCreated   Team[]   @relation("TeamCreatedBy")
  teamsUpdated   Team[]   @relation("TeamUpdatedBy")

  employees      Employee[] @relation("EmployeeUser")
  employeesCreated Employee[] @relation("EmpCreatedBy")
  employeesUpdated Employee[] @relation("EmpUpdatedBy")

  emissionSourcesCreated EmissionSource[] @relation("SrcCreatedBy")
  emissionSourcesUpdated EmissionSource[] @relation("SrcUpdatedBy")

  carbonEmissionsCreated CarbonEmission[] @relation("CarCreatedBy")
  carbonEmissionsUpdated CarbonEmission[] @relation("CarUpdatedBy")

  energyConsumptionsCreated EnergyConsumption[] @relation("EneCreatedBy")
  energyConsumptionsUpdated EnergyConsumption[] @relation("EneUpdatedBy")

  waterConsumptionsCreated WaterConsumption[] @relation("WatCreatedBy")
  waterConsumptionsUpdated WaterConsumption[] @relation("WatUpdatedBy")

  wasteManagementsCreated WasteManagement[] @relation("WstCreatedBy")
  wasteManagementsUpdated WasteManagement[] @relation("WstUpdatedBy")

  renewableEnergiesCreated RenewableEnergy[] @relation("RenCreatedBy")
  renewableEnergiesUpdated RenewableEnergy[] @relation("RenUpdatedBy")

  environmentalGoalsCreated EnvironmentalGoal[] @relation("EnvCreatedBy")
  environmentalGoalsUpdated EnvironmentalGoal[] @relation("EnvUpdatedBy")

  csrActivitiesCreated CsrActivity[] @relation("CsrCreatedBy")
  csrActivitiesUpdated CsrActivity[] @relation("CsrUpdatedBy")

  employeeParticipationCreated EmployeeParticipation[] @relation("PartCreatedBy")
  employeeParticipationUpdated EmployeeParticipation[] @relation("PartUpdatedBy")

  volunteerProgramsCreated VolunteerProgram[] @relation("VolCreatedBy")
  volunteerProgramsUpdated VolunteerProgram[] @relation("VolUpdatedBy")

  trainingRecordsCreated TrainingRecord[] @relation("TraCreatedBy")
  trainingRecordsUpdated TrainingRecord[] @relation("TraUpdatedBy")

  healthSafetyMetricsCreated HealthSafetyMetric[] @relation("HseCreatedBy")
  healthSafetyMetricsUpdated HealthSafetyMetric[] @relation("HseUpdatedBy")

  diversityMetricsCreated DiversityMetric[] @relation("DivCreatedBy")
  diversityMetricsUpdated DiversityMetric[] @relation("DivUpdatedBy")

  auditsCreated   Audit[]  @relation("AudCreatedBy")
  auditsUpdated   Audit[]  @relation("AudUpdatedBy")

  complianceIssuesCreated ComplianceIssue[] @relation("ComCreatedBy")
  complianceIssuesUpdated ComplianceIssue[] @relation("ComUpdatedBy")

  policiesCreated Policy[] @relation("PolCreatedBy")
  policiesUpdated Policy[] @relation("PolUpdatedBy")

  riskRegistersCreated RiskRegister[] @relation("RskCreatedBy")
  riskRegistersUpdated RiskRegister[] @relation("RskUpdatedBy")

  boardMembersCreated BoardMember[] @relation("BrdCreatedBy")
  boardMembersUpdated BoardMember[] @relation("BrdUpdatedBy")

  incidentsCreated Incident[] @relation("IncCreatedBy")
  incidentsUpdated Incident[] @relation("IncUpdatedBy")

  challengesCreated Challenge[] @relation("ChaCreatedBy")
  challengesUpdated Challenge[] @relation("ChaUpdatedBy")

  rewardsCreated Reward[]  @relation("RewCreatedBy")
  rewardsUpdated Reward[]  @relation("RewUpdatedBy")

  badgesCreated   Badge[]  @relation("BadCreatedBy")
  badgesUpdated   Badge[]  @relation("BadUpdatedBy")

  pointsLedgersCreated PointsLedger[] @relation("PtsCreatedBy")
  pointsLedgersUpdated PointsLedger[] @relation("PtsUpdatedBy")

  leaderboardsCreated Leaderboard[] @relation("LdbCreatedBy")
  leaderboardsUpdated Leaderboard[] @relation("LdbUpdatedBy")

  reportTemplatesCreated ReportTemplate[] @relation("RptCreatedBy")
  reportTemplatesUpdated ReportTemplate[] @relation("RptUpdatedBy")

  generatedReportsCreated GeneratedReport[] @relation("GenCreatedBy")
  generatedReportsUpdated GeneratedReport[] @relation("GenUpdatedBy")

  kpiMetricsCreated KpiMetric[] @relation("KpiCreatedBy")
  kpiMetricsUpdated KpiMetric[] @relation("KpiUpdatedBy")

  notificationsCreated Notification[] @relation("NotCreatedBy")
  notificationsUpdated Notification[] @relation("NotUpdatedBy")
  notificationsReceived Notification[] @relation("NotReceived")

  activityLogsCreated ActivityLog[] @relation("ActCreatedBy")
  activityLogsUpdated ActivityLog[] @relation("ActUpdatedBy")
  activityLogs        ActivityLog[] @relation("ActUser")

  auditLogsCreated AuditLog[] @relation("AudLogCreatedBy")
  auditLogsUpdated AuditLog[] @relation("AudLogUpdatedBy")
  auditLogs        AuditLog[] @relation("AudLogUser")

  settingsCreated Setting[] @relation("SetCreatedBy")
  settingsUpdated Setting[] @relation("SetUpdatedBy")

  @@map("users")
}

model Role {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  name           String   @db.VarChar(100)
  description    String?
  isSystem       Boolean  @default(false) @map("is_system")
  
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  createdBy      String?  @map("created_by") @db.Uuid
  updatedBy      String?  @map("updated_by") @db.Uuid
  isDeleted      Boolean  @default(false) @map("is_deleted")
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  createdByUser  User?    @relation("RoleCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict, onUpdate: Restrict)
  updatedByUser  User?    @relation("RoleUpdatedBy", fields: [updatedBy], references: [id], onDelete: Restrict, onUpdate: Restrict)

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  action         String   @db.VarChar(100)
  description    String?
  
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  createdBy      String?  @map("created_by") @db.Uuid
  updatedBy      String?  @map("updated_by") @db.Uuid
  isDeleted      Boolean  @default(false) @map("is_deleted")
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  createdByUser  User?    @relation("PermissionCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict, onUpdate: Restrict)
  updatedByUser  User?    @relation("PermissionUpdatedBy", fields: [updatedBy], references: [id], onDelete: Restrict, onUpdate: Restrict)

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  createdBy    String?  @map("created_by") @db.Uuid
  updatedBy    String?  @map("updated_by") @db.Uuid
  isDeleted    Boolean  @default(false) @map("is_deleted")
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz

  role         Role        @relation(fields: [roleId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  permission   Permission  @relation(fields: [permissionId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  createdByUser User?      @relation("RolePermCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict, onUpdate: Restrict)
  updatedByUser User?      @relation("RolePermUpdatedBy", fields: [updatedBy], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@unique([roleId, permissionId], name: "uq_role_permission")
  @@map("role_permissions")
}

model UserRole {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  createdBy String?  @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid
  isDeleted Boolean  @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  user      User     @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  createdByUser User? @relation("UserRoleCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict, onUpdate: Restrict)
  updatedByUser User? @relation("UserRoleUpdatedBy", fields: [updatedBy], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@unique([userId, roleId], name: "uq_user_role")
  @@map("user_roles")
}

// ==========================================
// 2. ORGANIZATION STRUCTURE MODULE
// ==========================================

model Location {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId     String   @map("organization_id") @db.Uuid
  name               String   @db.VarChar(255)
  type               String   @db.VarChar(100)
  address            String?  @db.VarChar(255)
  city               String?  @db.VarChar(100)
  region             String?  @db.VarChar(100)
  country            String   @db.VarChar(100)
  latitude           Decimal? @db.Decimal(9, 6)
  longitude          Decimal? @db.Decimal(9, 6)
  gridEmissionFactor Decimal? @map("grid_emission_factor") @db.Decimal(12, 6)
  
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  createdBy          String?  @map("created_by") @db.Uuid
  updatedBy          String?  @map("updated_by") @db.Uuid
  isDeleted          Boolean  @default(false) @map("is_deleted")
  deletedAt          DateTime? @map("deleted_at") @db.Timestamptz

  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  createdByUser      User?    @relation("LocCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict, onUpdate: Restrict)
  updatedByUser      User?    @relation("LocUpdatedBy", fields: [updatedBy], references: [id], onDelete: Restrict, onUpdate: Restrict)

  departments         Department[]
  employees           Employee[]
  emissionSources     EmissionSource[]
  carbonEmissions     CarbonEmission[]
  energyConsumptions  EnergyConsumption[]
  waterConsumptions   WaterConsumption[]
  wasteManagements    WasteManagement[]
  renewableEnergies   RenewableEnergy[]
  healthSafetyMetrics HealthSafetyMetric[]
  audits              Audit[]
  incidents           Incident[]

  @@map("locations")
}

model Department {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  locationId     String?  @map("location_id") @db.Uuid
  name           String   @db.VarChar(255)
  code           String?  @db.VarChar(50)
  
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  createdBy      String?  @map("created_by") @db.Uuid
  updatedBy      String?  @map("updated_by") @db.Uuid
  isDeleted      Boolean  @default(false) @map("is_deleted")
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  location       Location?    @relation(fields: [locationId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  createdByUser  User?    @relation("DeptCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict, onUpdate: Restrict)
  updatedByUser  User?    @relation("DeptUpdatedBy", fields: [updatedBy], references: [id], onDelete: Restrict, onUpdate: Restrict)

  teams          Team[]
  employees      Employee[]

  @@map("departments")
}

model Team {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  departmentId String   @map("department_id") @db.Uuid
  name         String   @db.VarChar(255)
  
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  createdBy    String?  @map("created_by") @db.Uuid
  updatedBy    String?  @map("updated_by") @db.Uuid
  isDeleted    Boolean  @default(false) @map("is_deleted")
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz

  department   Department @relation(fields: [departmentId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  createdByUser User?    @relation("TeamCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict, onUpdate: Restrict)
  updatedByUser User?    @relation("TeamUpdatedBy", fields: [updatedBy], references: [id], onDelete: Restrict, onUpdate: Restrict)

  employees    Employee[]

  @@map("teams")
}

model Employee {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String?  @map("user_id") @db.Uuid
  teamId       String?  @map("team_id") @db.Uuid
  departmentId String   @map("department_id") @db.Uuid
  locationId   String   @map("location_id") @db.Uuid
  employeeCode String   @map("employee_code") @db.VarChar(100)
  jobTitle     String?  @map("job_title") @db.VarChar(150)
  gender       String?  @db.VarChar(50)
  ageGroup     String?  @map("age_group") @db.VarChar(50)
  hireDate     DateTime? @map("hire_date") @db.Date
  
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  createdBy    String?  @map("created_by") @db.Uuid
  updatedBy    String?  @map("updated_by") @db.Uuid
  isDeleted    Boolean  @default(false) @map("is_deleted")
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz

  user         User?      @relation("EmployeeUser", fields: [userId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  team         Team?      @relation(fields: [teamId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  location     Location   @relation(fields: [locationId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  createdByUser User?    @relation("EmpCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict, onUpdate: Restrict)
  updatedByUser User?    @relation("EmpUpdatedBy", fields: [updatedBy], references: [id], onDelete: Restrict, onUpdate: Restrict)

  participations  EmployeeParticipation[]
  trainingRecords TrainingRecord[]
  incidents       Incident[]
  pointsLedgers   PointsLedger[]

  @@unique([locationId, employeeCode], name: "uq_employee_code_org")
  @@map("employees")
}

// ==========================================
// 3. ENVIRONMENTAL MODULE
// ==========================================

model EmissionSource {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  locationId     String   @map("location_id") @db.Uuid
  name           String   @db.VarChar(255)
  scope          String   @db.VarChar(50)
  sourceType     String   @map("source_type") @db.VarChar(100)
  fuelType       String?  @map("fuel_type") @db.VarChar(100)
  unitOfMeasure  String   @map("unit_of_measure") @db.VarChar(50)
  emissionFactor Decimal  @map("emission_factor") @db.Decimal(12, 6)
  
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  createdBy      String?  @map("created_by") @db.Uuid
  updatedBy      String?  @map("updated_by") @db.Uuid
  isDeleted      Boolean  @default(false) @map("is_deleted")
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz

  location       Location @relation(fields: [locationId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  createdByUser  User?    @relation("SrcCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict, onUpdate: Restrict)
  updatedByUser  User?    @relation("SrcUpdatedBy", fields: [updatedBy], references: [id], onDelete: Restrict, onUpdate: Restrict)

  carbonEmissions CarbonEmission[]

  @@map("emission_sources")
}

model CarbonEmission {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId   String   @map("organization_id") @db.Uuid
  locationId       String   @map("location_id") @db.Uuid
  emissionSourceId String   @map("emission_source_id") @db.Uuid
  startDate        DateTime @map("start_date") @db.Date
  endDate          DateTime @map("end_date") @db.Date
  rawValue         Decimal  @map("raw_value") @db.Decimal(15, 4)
  co2EmissionsMt   Decimal  @map("co2_emissions_mt") @db.Decimal(15, 6)
  ch4EmissionsMt   Decimal  @map("ch4_emissions_mt") @db.Decimal(15, 6)
  n2oEmissionsMt   Decimal  @map("n2o_emissions_mt") @db.Decimal(15, 6)
  totalCo2eMt      Decimal  @map("total_co2e_mt") @db.Decimal(15, 6)
  calculationMethod String? @map("calculation_method")
  
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  createdBy        String?  @map("created_by") @db.Uuid
  updatedBy        String?  @map("updated_by") @db.Uuid
  isDeleted        Boolean  @default(false) @map("is_deleted")
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz

  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  location         Location     @relation(fields: [locationId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  emissionSource   EmissionSource @relation(fields: [emissionSourceId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  createdByUser    User?    @relation("CarCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict, onUpdate: Restrict)
  updatedByUser    User?    @relation("CarUpdatedBy", fields: [updatedBy], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@map("carbon_emissions")
}

model EnergyConsumption {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId   String   @map("organization_id") @db.Uuid
  locationId       String   @map("location_id") @db.Uuid
  utilityName      String?  @map("utility_name") @db.VarChar(150)
  energyType       String   @map("energy_type") @db.VarChar(100)
  consumptionValue Decimal  @map("consumption_value") @db.Decimal(15, 4)
  unit             String   @db.VarChar(50)
  cost             Decimal? @db.Decimal(12, 2)
  currency         String?  @db.VarChar(10)
  startDate        DateTime @map("start_date") @db.Date
  endDate          DateTime @map("end_date") @db.Date
  
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  createdBy        String?  @map("created_by") @db.Uuid
  updatedBy        String?  @map("updated_by") @db.Uuid
  isDeleted        Boolean  @default(false) @map("is_deleted")
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz

  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  location         Location     @relation(fields: [locationId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  createdByUser    User?    @relation("EneCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict, onUpdate: Restrict)
  updatedByUser    User?    @relation("EneUpdatedBy", fields: [updatedBy], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@map("energy_consumption")
}

model WaterConsumption {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId     String   @map("organization_id") @db.Uuid
  locationId         String   @map("location_id") @db.Uuid
  sourceType         String   @map("source_type") @db.VarChar(100)
